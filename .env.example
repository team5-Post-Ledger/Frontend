# 백엔드 모듈별 로컬 포트 (2번 개발자 API 명세서 v2 기준 기본값)
# 이 파일을 .env.local로 복사한 뒤, 자기 로컬에서 뜨는 실제 포트로 값만 바꿔서 쓴다.
# .env.local은 .gitignore(*.local)로 무시되므로 커밋되지 않는다.
VITE_API_VISITOR_PORT=8082
VITE_API_EXPO_ADMIN_PORT=8083
VITE_API_PLATFORM_ADMIN_PORT=8084
VITE_API_EXHIBITOR_PORT=8085

# 백엔드 실연동 전역 토글.
# 값을 비워두거나 안 넣으면 기본 true → 전부 mock으로 동작(지금까지와 동일).
# 실서버에 붙여 테스트하려면 .env.local에서 아래를 false로 둔다.
# 아직 실API로 변환하지 않은 도메인은 이 값과 무관하게 항상 mock을 반환하므로 부분 연동이 안전하다.
VITE_USE_MOCK=true
